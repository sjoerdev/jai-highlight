{
    "name": "jai-syntax",
    "version": "0.0.1",
    "publisher": "sjoerdev",
    "repository": {
        "type": "git",
        "url": "https://github.com/sjoerdev/jai-highlight"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "contributes": {
        "languages": [
            {
                "id": "jai",
                "aliases": [
                    "Jai",
                    "jai"
                ],
                "extensions": [
                    ".jai"
                ],
                "configuration": "./syntaxes/jai-config.json"
            }
        ],
        "grammars": [
            {
                "language": "jai",
                "scopeName": "source.jai",
                "path": "./syntaxes/jai-textmate.json"
            }
        ]
    }
}